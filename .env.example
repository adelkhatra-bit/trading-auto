# Exemple de fichier .env
# Copier ce fichier en .env et remplir les valeurs réelles avant de lancer le serveur

# ===== SERVICE FICHIER =====
FILE_URL=https://example.com/data.csv
ACCESS_METHOD=public
# ACCESS_METHOD peut être: public | token | onedrive
FILE_BEARER_TOKEN=
# Token requis si ACCESS_METHOD=token (sinon laisser vide)

# ===== SERVEUR =====
PORT=4000
NODE_ENV=development
SAFE_MODE=0

# ===== TRADING - PAPIER/LIVE =====
BROKER_MODE=live
# BROKER_MODE peut être: paper (simulation) | live (ordres réels)
BROKER_ENDPOINT=https://api.broker.example.com/trade
BROKER_API_KEY=your-broker-api-key
BROKER_API_SECRET=your-broker-api-secret

# ===== PORTEFEUILLE & RISQUE =====
ACCOUNT_BALANCE=100000
# Balance initiale du compte (en devise locale)
RISK_PERCENT=1
# Pourcentage de risque par trade (0.5 - 5)

# ===== LIMITES & TIMEOUTS =====
MAX_FILE_SIZE=10485760
# Taille max fichier téléchargeable (bytes) - defaut 10MB
REQUEST_TIMEOUT=20000
# Timeout requêtes externes (ms) - defaut 20s

# ===== LOGGING (optionnel) =====
LOG_LEVEL=info
# Optionnel: debug | info | warn | error
