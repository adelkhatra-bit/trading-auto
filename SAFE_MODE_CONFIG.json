      "now": "DISABLED - call /mt5/status on demand",
      "reactivate": "POST /mt5/health-check/enable?interval=60000"
    },
    "analysis_auto_loop": {
      "was": "setInterval(analyze, 2000) - polling every 2 seconds",
      "why": "Excessive fs.readFileSync + JSON.parse in tight loop",
      "now": "DISABLED - call analyze via POST /analyze",
      "reactivate": "POST /analyzer/enable?interval=5000 (minimum 1000ms)"
    },
    "continuous_orchestration": {
      "was": "setInterval(runOrchestrationCycle, 30000) - every 30 seconds",
      "why": "Ran regardless of active symbol - wasted CPU between trades",
