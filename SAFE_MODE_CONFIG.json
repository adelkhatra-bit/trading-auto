      "GET /orchestration-status": "Is orchestration auto running?",
      "GET /mt5/status": "MT5 bridge connectivity",
      "POST /mt5/health-check/enable": "Start MT5 health checks",
      "POST /mt5/health-check/disable": "Stop MT5 health checks"
