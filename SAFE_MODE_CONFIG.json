    "manual_triggers": {
      "POST /orchestration/run-now": "Execute one orchestration cycle NOW",
      "POST /check-agent-tasks": "Poll tasks.json once",
      "POST /analyze": "Run analysis once",
      "POST /analyze/enable": "Enable auto-analysis with interval"
    }
  },
  "guidelines": {
    "rule_1": "Never enable multiple automatic loops simultaneously",
    "rule_2": "Minimum interval between cycles: 1000ms (1 second)",
    "rule_3": "Prefer HTTP polling (on-demand) over continuous loops",
    "rule_4": "If CPU > 50%, disable auto features immediately",
    "rule_5": "Monitor /system-log for 'error' or 'warn' status"
  },
  "reactivationSteps": {
    "step_1": "Verify system is stable (CPU < 30%, Memory < 500MB for Node)",
    "step_2": "Start with one feature only",
    "step_3": "Use large intervals first (e.g., 60000ms = 60 seconds)",
    "step_4": "Monitor /health endpoint continuously",
    "step_5": "Gradually reduce intervals if needed"
  },
  "emergencyShutdown": {
    "windows": "taskkill /F /IM node.exe",
    "linux": "pkill -9 node",
    "curl": "curl -X POST http://localhost:4000/orchestration/disable && curl -X POST http://localhost:4000/mt5/health-check/disable"
  }
