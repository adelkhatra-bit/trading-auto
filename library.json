  "workflow": {
    "mandatory_7_steps": [
      "1. ANALYSE (agent-memory verify existence)",
      "2. COMPRÉHENSION (understand structure)",
      "3. LOCALISATION (identify exact location)",
      "4. RÉPARATION (generate fix)",
      "5. TEST (agent-testeur validation)",
      "6. VALIDATION (if important, request approval)",
      "7. INTÉGRATION (only if 1-6 OK)"
    ],
    "blocking_points": [
      "Step 1: No agent-memory check = BLOCKED",
      "Step 5: No test-agent validation = BLOCKED",
      "Step 5 FAIL: No integration until fixed",
      "Step 7: Only if all previous OK"
    ]
  },

  "system_constraints": {
    "performance": "No auto-polling every 2s (SSE only)",
    "stability": "Zero breaking changes (enrich, don't replace)",
    "traceability": "workflow.json logs every step",
    "testing": "No integration without test-agent approval",
    "memory": "No duplicate concepts (agent-memory validates)"
  }
