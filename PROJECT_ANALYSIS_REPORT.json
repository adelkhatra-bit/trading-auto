    "keyArchitecturalPoints": [
      "marketStore acts as central in-memory cache (no database)",
      "normalizeSymbol handles XAUUSD ↔ XAU/USD conversions",
      "zoneManager tracks supply/demand zones with auto-deactivation",
      "orchestrator runs tradingCore, tfConsensus, fearIndex, newsIntelligence in parallel",
      "SSE /stream broadcasts live price updates to connected studio clients",
      "4-tier fallback ensures always-available prices (MT5 → TV → Yahoo → fixture)"
    ]
